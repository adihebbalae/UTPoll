{
  "manifest_version": 3,
  "name": "UT Instapoll Alert",
  "version": "1.0.3",
  "description": "Monitors UT Instapoll and fires audio, desktop, and push alerts the moment a live poll is detected.",

  "permissions": ["notifications", "storage", "offscreen", "tabs"],
  "host_permissions": ["*://polls.la.utexas.edu/*", "https://ntfy.sh/*", "wss://pusher-ws.la.utexas.edu/*", "http://localhost:8080/*"],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://ntfy.sh;"
  },
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://polls.la.utexas.edu/*", "http://localhost:8080/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://polls.la.utexas.edu/*", "http://localhost:8080/*"]
    }
  ]
}
