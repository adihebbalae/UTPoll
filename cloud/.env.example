# Instapoll Cloud Notifier — environment variables
# Copy this file to .env for local development.
# Never commit a .env file with real values.

# Numeric Instapoll course ID (visible in the URL when you open a course).
# Example: for polls.la.utexas.edu/student/course/6104/... use 6104.
# Update each semester.
COURSE_ID=

# ntfy.sh topic name. Use a long random string (e.g. a UUID) so that
# your notifications cannot be read by anyone who guesses the topic.
# Generate one with: python -c "import uuid; print(uuid.uuid4())"
NTFY_TOPIC=
